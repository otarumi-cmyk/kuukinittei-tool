# Streamlit Cloud のアプリ設定 → Secrets に貼り付ける内容のサンプル
# このファイル自体は GitHub にコミットしてOK（値は入っていない）。
# 実際の secrets.toml はローカルでも GitHub でも管理しない（.gitignoreで除外）。

# アプリのパスワード
app_password = "your-strong-password-here"

# token.json の中身を文字列としてそのまま貼る（"""～"""で囲む）
token_json = """
{
  "token": "...",
  "refresh_token": "...",
  "client_id": "...",
  "client_secret": "...",
  "scopes": ["https://www.googleapis.com/auth/calendar.readonly"],
  ...
}
"""
